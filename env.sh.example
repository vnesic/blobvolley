#!/bin/bash
# ============================================
# Blob Volley - Release Signing Configuration
# ============================================
#
# SETUP:
# 1. Copy this file: cp env.sh.example env.sh
# 2. Fill in your actual values in env.sh
# 3. Source before building: source env.sh
# 4. Build: ./gradlew bundleRelease
#
# IMPORTANT: Never commit env.sh to git!
# ============================================

# Path to your keystore file (relative to app/ directory or absolute)
export RELEASE_STORE_FILE="../blobvolley-release.keystore"

# Keystore password (set when you created the keystore)
export RELEASE_STORE_PASSWORD="your_keystore_password_here"

# Key alias (use: blobvolley)
export RELEASE_KEY_ALIAS="blobvolley"

# Key password (often same as keystore password)
export RELEASE_KEY_PASSWORD="your_key_password_here"

echo "✓ Release signing environment configured"